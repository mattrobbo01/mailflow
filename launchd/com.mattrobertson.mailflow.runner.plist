<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.mattrobertson.mailflow.runner</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Applications/MailFlow.app/Contents/MacOS/MailFlow</string>
    <string>--runner</string>
  </array>
  <key>StartInterval</key>
  <integer>60</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/mailflow-runner.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/mailflow-runner.log</string>
  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
