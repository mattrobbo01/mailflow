{
  "name": "mailflow",
  "version": "1.0.0",
  "description": "Local-first Gmail client with Superhuman UX, local meeting transcription, and a HubSpot people sidebar",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
